# Generated by Cargo
debug/
target/

# Cargo.lock is committed for the binary so Docker builds are reproducible.

# rustfmt backups
**/*.rs.bk

*.pdb

# Config + secrets (PandaScore token, VAPID keys)
config.toml
.env
.envrc

# SQLite cache (runtime data)
data/
*.db
*.db-wal
*.db-shm

# Optional drop-in site icons (generated by scripts/icons/generate.sh)
/icons/

# Playwright/research artifacts
.playwright-mcp/

# MacOS Artifacts
.DS_Store

# Claude
.claude/*

# Ephemeral, feature-building docs (plans/specs/scratch from the dev workflow).
# Keep these local — don't commit them. Real setup/usage docs live in README.md.
# See CLAUDE.md.
/docs/superpowers/

# dhat allocation profiler output (written by examples/alloc_profile.rs).
dhat-heap.json
