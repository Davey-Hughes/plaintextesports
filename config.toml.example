# plaintextesports configuration. Copy to config.toml and edit.
# Any matching env var (e.g. DEMO=1) overrides the value here.

# PandaScore API token (free tier: https://pandascore.co, no card). Omit to
# serve demo data.
pandascore_token = ""

# Orange Cat Blacktop API key (https://ocblacktop.com/api) — adds WRC + WEC +
# MotoGP. Free tier is 250 req/day; these series are polled conservatively
# (schedule first) and served from cache, so it fits easily. Omit to skip them.
ocblacktop_token = ""

# Twitch app credentials (https://dev.twitch.tv/console/apps — free) for the
# esports live-stream enrichment: live status + viewer counts on match streams,
# plus optional curated co-streamers. Server-to-server client-credentials flow;
# both are required to activate it. Omit to skip Twitch enrichment.
twitch_client_id = ""
twitch_client_secret = ""

# YouTube Data API v3 key (https://console.cloud.google.com — free, quota-limited,
# billing not required) for YouTube live-stream enrichment: live status + viewer
# counts on YouTube streams / co-streamers, and WEC's YouTube broadcast. Live
# checks are cheap (uploads + videos.list) and capped by a persisted daily-unit
# budget. Omit to skip YouTube enrichment.
youtube_api_key = ""

# Curated YouTube co-streamers, same game/league keys as [costreamers] (values are
# channel handles or URLs). Shown when live; NOT game-filtered (YouTube has no
# reliable game signal), so curate per game.
# [youtube_costreamers]
# lol = ["@caedrel", "https://www.youtube.com/@sneaky"]

# SOOP (formerly AfreecaTV) is Korea's dominant platform, where LCK and Korean
# pro-player streams live instead of Twitch. Enabling this marks SOOP streams on a
# match live and shows their viewer counts (and surfaces curated SOOP co-streamers
# below). It uses SOOP's unofficial station endpoint — no API key, but off by
# default because it's unofficial. Set true to opt in.
# soop_enabled = true

# Curated SOOP co-streamers, same game/league keys as [costreamers] (values are
# SOOP broadcaster ids, e.g. the "<id>" in sooplive.com/<id>). Shown when live;
# NOT game-filtered, so curate per game. Requires soop_enabled = true.
# [soop_costreamers]
# lol = ["lck", "faker"]

# TFT (Teamfight Tactics) esports schedule + final placements. No commercial
# esports data API covers TFT, so this parses Liquipedia's public MediaWiki pages
# (contact User-Agent, gzip, slow polling + aggressive caching per their API
# terms; CC-BY-SA attribution is shown in the footer). Off by default because it
# scrapes rendered wiki HTML. Set true to add a "TFT" chip to the esports schedule
# (and final placements on TFT event pages once tournaments finish).
# liquipedia_enabled = true

# Curated co-streamers (Twitch logins), shown on a match's page when they're live
# and streaming that match's game. Two kinds of key, merged for each match:
#   - a game key = the sport slug ("lol" or "cs2") applies to EVERY league of that
#     game (the usual case);
#   - a league key = the league name exactly as it appears on the site adds
#     league-specific extras on top. Most useful for a league whose own broadcast
#     ISN'T on Twitch (so it never shows natively) — e.g. LPL streams on Huya, so
#     its official English Twitch cast is worth adding here. A league that already
#     streams on Twitch (LCK/LEC/LCS) needs no entry — its channel shows and gets
#     the live badge on its own.
# [costreamers]
# lol = ["caedrel", "doublelift", "sneaky"]
# cs2 = ["ohnepixel"]
# tft = ["k3soju", "mortdog"]   # TFT players/creators who stream these events
# LPL = ["lpl"]

# Discover unlisted co-streamers by scanning a match's Twitch game category while
# it's live (opt-in; omit the table to disable). Needs twitch_client_id/secret
# above. A discovered stream is attached to a league's live match when its title
# or tags contain one of that league's keywords (see [twitch_league_aliases]).
# [twitch_discovery]
# enabled_sports = ["lol", "cs2", "tft"]  # sport slugs; empty/absent = off
# languages      = ["en"]           # only surface streams in these languages
# min_viewers    = 300              # skip streams below this viewer count
# max_per_match  = 6                # cap appended co-streams (highest-viewer first)
# gql_costreamers = false           # Phase 2: official co-streamers via unofficial GQL — keep off
# Optional: override the built-in sport-slug -> Twitch category id map.
# [twitch_discovery.game_ids]
# lol = "21779"
# cs2 = "32399"
# tft = "513143"

# League name (exactly as stored) -> Twitch title keywords, so a stream titled
# "MSI ..." attaches to the "Mid-Season Invitational" league. Most leagues already
# ARE the term streamers type — LCK, LEC, LPL, IEM, Worlds — so they match with no
# alias via the raw-league-name fallback; add an entry only where the stored name
# differs from what streamers write (MSI is the main one).
# [twitch_league_aliases]
# "Mid-Season Invitational" = ["MSI"]   # LoL
# "ESL Pro League" = ["EPL"]            # CS2
# "BLAST Premier" = ["BLAST"]           # CS2

# Poll cadence (seconds). Each series (WRC, WEC, MotoGP) is polled independently,
# only as fast as its nearest event warrants, so a quiet day costs a handful of
# requests and even a race day stays well under the free tier's 250/day. The
# per-series tiers:
#   live — a session of THAT series is running or starts within the hour
#   near — that series has an event within ~2 weeks
#   idle — nothing close (off-season / between rounds): the passive baseline
# Only the in-window series uses the fast tier; the rest stay idle. Standings only
# change after a round, so they sit on a daily floor and also refresh within the
# `near` interval once a round finishes. The daily cap is a hard backstop; the
# request budget and per-series gates are persisted to the cache DB, so restarting
# the server resumes the day instead of re-polling or resetting the count. Defaults
# shown — uncomment to tune.
# ocblacktop_live_poll_secs = 300         # live/imminent session (min 60)
# ocblacktop_near_poll_secs = 10800       # event within ~2 weeks (min 300)
# ocblacktop_idle_poll_secs = 86400       # off-season / between rounds (min 3600)
# ocblacktop_standings_poll_secs = 86400  # standings daily floor (min 3600)
# ocblacktop_daily_cap = 240              # hard per-UTC-day request ceiling (tier is 250)

# Force demo/fixture data, ignoring the token + cache DB (dev/UI work).
# demo = true

# Timezone for the first server render / non-JS clients (viewers' own tz is
# auto-detected in the browser). IANA name.
display_tz = "America/Los_Angeles"

# Days ahead shown on the homepage (1-60).
upcoming_days = 30

# Poll cadence in seconds: idle (nothing live) and active (live/imminent).
idle_poll_secs = 1200
active_poll_secs = 60

# How long before a match starts to send its reminder, in minutes (0-1440).
reminder_lead_minutes = 15

# Months of past matches to keep and backfill (1-3; the free tier's history is
# shallow). Older finished events stay browsable via "show earlier days" / the
# calendar.
archive_months = 1

# Days to keep a persisted match box score after it was last fetched/viewed
# before pruning it from the on-disk cache (0-3650; 0 disables pruning). Box
# scores are cached per game, so this bounds slow disk growth; an evicted one is
# simply re-fetched on the next view. Viewing a game refreshes its timer.
box_score_retention_days = 540

# Periodically re-fetch recent past days for late score corrections (sparse:
# ~6h for yesterday, slowing to never past a week). Disable to save quota.
# PandaScore (CS2/LoL) only — the traditional sports come from separate keyless
# feeds with fixed histories, so this has no effect on them.
past_refresh = true

# On a fresh DB, slowly backfill older matches back to archive_months, only when
# there's spare API budget (current/future polling always has priority).
# PandaScore (CS2/LoL) only, like past_refresh.
backfill = true

# Skip the low-priority past-refresh/backfill work while PandaScore's remaining
# hourly budget is below this, reserving headroom for current/future polling. A
# priority threshold, not a global rate limiter — the main poll always runs.
rate_limit_floor = 200

# SQLite cache path (persists matches/links/reminders). "" disables persistence.
db_path = "data/cache.db"

# Resolve exact event pages via Liquipedia (cached).
resolve_links = true

# Directory the server reads optional site-icon / PWA files from at runtime.
# Drop the output of scripts/icons/generate.sh here (favicon.ico, favicon.svg,
# apple-touch-icon.png, icon-192.png, icon-512.png, icon-512-maskable.png,
# manifest.webmanifest). Present files are served and linked in <head>; if the
# directory is empty the site behaves as before (no favicon, no manifest).
# Adding/removing files takes effect for the <head> links on the next restart;
# the files themselves are served live. Default: "icons" (relative to CWD).
# icons_dir = "icons"

# Web Push reminders. Generate keys once with:
#   cargo run --example gen_vapid --features ssr
# All three required to enable reminders.
[vapid]
public = ""
private = ""
subject = "mailto:you@example.com"

# Footer copyright + links (all optional).
[site]
# Just the holder name — "© <current year>" is prepended automatically.
copyright = "Your Name"
# When set, the copyright line becomes a link to this URL.
# copyright_url = "https://your-site.example"
links = [
  { label = "GitHub", url = "https://github.com/you/plaintextesports" },
  # { label = "Twitter", url = "https://twitter.com/you" },
]
