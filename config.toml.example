# plaintextesports configuration. Copy to config.toml and edit.
# Any matching env var (e.g. DEMO=1) overrides the value here.

# PandaScore API token (free tier: https://pandascore.co, no card). Omit to
# serve demo data.
pandascore_token = ""

# Orange Cat Blacktop API key (https://ocblacktop.com/api) — adds WRC + WEC +
# MotoGP. Free tier is 250 req/day; these series are polled conservatively
# (schedule first) and served from cache, so it fits easily. Omit to skip them.
ocblacktop_token = ""
# How often to refresh the calendars / standings (seconds), and a hard per-UTC-day
# request cap as a backstop under the 250/day free tier. A calendar refresh costs
# up to 4 requests (WRC + WEC + MotoGP, +1 for an active rally's stage timetable),
# a standings refresh 6, so the defaults below work out to ~144/day — under the cap
# with headroom for on-demand result fetches. Lower them only with quota to spare.
# ocblacktop_poll_secs = 3600
# ocblacktop_standings_poll_secs = 10800
# ocblacktop_daily_cap = 240

# Force demo/fixture data, ignoring the token + cache DB (dev/UI work).
# demo = true

# Timezone for the first server render / non-JS clients (viewers' own tz is
# auto-detected in the browser). IANA name.
display_tz = "America/Los_Angeles"

# Days ahead shown on the homepage (1-60).
upcoming_days = 30

# Poll cadence in seconds: idle (nothing live) and active (live/imminent).
idle_poll_secs = 1200
active_poll_secs = 60

# How long before a match starts to send its reminder, in minutes (0-1440).
reminder_lead_minutes = 15

# Months of past matches to keep and backfill (1-3; the free tier's history is
# shallow). Older finished events stay browsable via "show earlier days" / the
# calendar.
archive_months = 1

# Periodically re-fetch recent past days for late score corrections (sparse:
# ~6h for yesterday, slowing to never past a week). Disable to save quota.
# PandaScore (CS2/LoL) only — the traditional sports come from separate keyless
# feeds with fixed histories, so this has no effect on them.
past_refresh = true

# On a fresh DB, slowly backfill older matches back to archive_months, only when
# there's spare API budget (current/future polling always has priority).
# PandaScore (CS2/LoL) only, like past_refresh.
backfill = true

# Skip the low-priority past-refresh/backfill work while PandaScore's remaining
# hourly budget is below this, reserving headroom for current/future polling. A
# priority threshold, not a global rate limiter — the main poll always runs.
rate_limit_floor = 200

# SQLite cache path (persists matches/links/reminders). "" disables persistence.
db_path = "data/cache.db"

# Resolve exact event pages via Liquipedia (cached).
resolve_links = true

# Web Push reminders. Generate keys once with:
#   cargo run --example gen_vapid --features ssr
# All three required to enable reminders.
[vapid]
public = ""
private = ""
subject = "mailto:you@example.com"

# Footer copyright + links (all optional).
[site]
# Just the holder name — "© <current year>" is prepended automatically.
copyright = "Your Name"
# When set, the copyright line becomes a link to this URL.
# copyright_url = "https://your-site.example"
links = [
  { label = "GitHub", url = "https://github.com/you/plaintextesports" },
  # { label = "Twitter", url = "https://twitter.com/you" },
]
