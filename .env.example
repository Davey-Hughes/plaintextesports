# PandaScore API token (free tier: sign up at https://pandascore.co, no card required).
# Without a token the app serves the checked-in fixture data so the UI still works.
PANDASCORE_TOKEN=

# Timezone used to format match times and group matches by day (IANA name).
# Defaults to America/Los_Angeles.
DISPLAY_TZ=America/Los_Angeles

# Idle poll interval in seconds — used when nothing is live or starting soon.
# Schedules change slowly and the free tier has no live feed, so this is
# generous by default (1200 = 20 min, min 60).
POLL_INTERVAL_SECS=1200

# Active poll interval in seconds — used while a match is live or starts within
# ~15 min, to pick up final scores/status promptly (60 = 1 min, min 30).
POLL_ACTIVE_SECS=60

# How many days ahead the homepage "upcoming" view shows (1-60). Default 30.
UPCOMING_DAYS=30

# SQLite cache file path (persists matches across restarts). Default data/cache.db.
# Set to empty to disable persistence and run memory-only.
DB_PATH=data/cache.db

# Resolve exact event pages via Liquipedia's API (cached). Set to false/0 to
# disable and use generic links only. Default true.
ENABLE_LIQUIPEDIA=true

# Web Push reminders. Generate a keypair once with:
#   npx web-push generate-vapid-keys
# then paste below. Leave any blank to disable reminders. Requires DB_PATH and,
# in production, HTTPS. VAPID_SUBJECT is a contact mailto:/https: URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
